#!/bin/bash

RED="\e[0;31m"
GREEN="\e[0;32m"
RESET="\e[0m"

log() {
    echo -ne "${GREEN}info${RESET} | $1\n"
}

build_on() {
    log "system: $(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')"
}

error() {
    echo -ne "${RED}error${RESET} | $1\n"
    exit 1
}

docs() {
    RUSTFLAGS="-Awarnings" cargo doc || error "docs error caught."
}

build() {
    RUSTFLAGS="-Awarnings -C debuginfo=2" cargo build || error "build error caught."
}

test() {
    RUSTFLAGS="-Awarnings" cargo test || error "test error caught."
}

run() {
    if [[ ! -f ./target/debug/koshka2 ]]; then 
        error "couldn't find the Koshka II RS binary. run \"./ball -build\" first."
    fi
    ./target/debug/koshka2
}

clean() {
    rm -rf target/
}

release() {
    RUSTFLAGS="-Awarnings -gdwarf-5" cargo build --release || error "release error caught."
}

help() {
    echo "Usage: ./ball [OPTIONS]"
    echo "Options:"
    echo "  -build             Build the project"
    echo "  -test              Run tests"
    echo "  -docs              Assemble the docs"
    echo "  -run               Run the emulator"
    echo "  -full              Do everything (clean + build + test + run)"
    echo "  -clean             Remove the target/ directory"
    echo "  -h, --help         Show this help"
    exit 0
}

build_on
for arg in "$@"; do
    case $arg in
        -build) build | tee ball.log ;;
        -test) test | tee ball.log ;;
        -docs) docs | tee ball.log ;;
        -run) run | tee ball.log ;;
        -full) clean && test && build && run | tee ball.log ;;
        -h|-help) help ;;
        -clean) clean ;;
        -release) release ;;
        *)
            error "Unknown option: $arg. Use -h for help."
            ;;
    esac
done



if [[ $# -eq 0 ]]; then
    error "No arguments provided. Use -h for help."
fi
